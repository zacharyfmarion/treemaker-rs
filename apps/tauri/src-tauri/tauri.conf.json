{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TreeMaker",
  "version": "0.1.0",
  "identifier": "com.zacharymarion.treemaker",
  "build": {
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "../../web"
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "../../web"
    },
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "TreeMaker",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/icon.png"
    ]
  }
}
