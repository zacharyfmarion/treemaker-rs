# Copy to .env.release.local and fill values from your password manager.
# .env.release.local is ignored and should never be committed.

# GitHub release target. Override this if the repo is renamed.
RELEASE_GITHUB_REPO=zacharyfmarion/ori-studio
RELEASE_REMOTE=origin

# Required for signing and notarization.
APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"
APPLE_ID="you@example.com"
APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"
APPLE_TEAM_ID="TEAMID"

# Optional: only needed if the signing certificate is not already installed in
# your local login keychain. Keep this as one base64-encoded .p12 value.
# APPLE_CERTIFICATE="base64-encoded-p12"
# APPLE_CERTIFICATE_PASSWORD="p12-password"
